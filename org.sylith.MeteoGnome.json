{
  "app-id": "tech.sylith.MeteoApp",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "meteo-app",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "python3-requests",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app requests"
      ]
    },
    {
      "name": "python3-matplotlib",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app matplotlib --no-build-isolation"
      ]
    },
    {
      "name": "meteo-app",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
